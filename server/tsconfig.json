{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "node16",
    "moduleDetection": "force",
    "moduleResolution": "node16",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": false,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "config/**/*.ts",
    "controllers/**/*.ts",
    "mail/**/*.ts",
    "middlewares/**/*.ts",
    "models/**/*.ts",
    "routes/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
